# ============================================================
# Aura OS Docker — Environment Variables
# ============================================================
# Copy this file to docker/.env and fill in your values.
# docker/.env is git-ignored — NEVER commit it.
#
#   cp docker/.env.example docker/.env
# ============================================================

# ── Backend ──────────────────────────────────────────────────

# MongoDB Atlas connection string (required)
# Get this from: https://cloud.mongodb.com → Clusters → Connect
MONGO_URI=mongodb+srv://avcareer107_db_user:I3qykrx8PUGVLnjf@cluster0.jbww2vt.mongodb.net/?appName=Cluster0

# ── Frontend (dev mode — injected at runtime by Vite) ────────

# Backend API base URL as seen from the browser.
# In Docker dev mode this is handled by the Vite proxy — leave blank
# or set to /api. Only needed for the prod profile.
VITE_API_URL=https://aura-os-d88w.onrender.com/api

# CV service URL (optional — CV is local-only, not containerized)
VITE_CV_URL=http://localhost:8000

# Enable verbose debug logging (false in all deployed environments)
VITE_DEBUG=false
