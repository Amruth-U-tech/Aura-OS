# =============================================================
# Aura OS — Environment Variable Template
# =============================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For Vercel production deployment, set these variables in:
#   Vercel Dashboard → Project → Settings → Environment Variables
#
# NEVER commit .env or .env.production to source control.
# This file (.env.example) is safe to commit — it contains no secrets.
# =============================================================

# ------------------------------------------------------------
# Main Express/Node backend
# Local:       http://localhost:5000/api
# Production:  https://aura-os-d88w.onrender.com/api
# ------------------------------------------------------------
VITE_API_URL=http://localhost:5000/api

# ------------------------------------------------------------
# FastAPI Computer Vision backend
# Local:       http://localhost:8000
# Production:  https://<your-cv-service>.onrender.com
# (If CV service is not deployed, DisciplineMode degrades
#  gracefully — it catches fetch errors without crashing.)
# ------------------------------------------------------------
VITE_CV_URL=http://localhost:8000

# ------------------------------------------------------------
# Debug flag — enables verbose [API] console logs
# true  → logs active (use in dev)
# false → silent    (use in production)
# ------------------------------------------------------------
VITE_DEBUG=true
